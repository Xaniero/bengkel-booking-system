# Contoh isi file .env.
# Cara pakai: salin file ini, ubah namanya jadi ".env", lalu isi datanya.

# ===== Database (XAMPP) =====
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bengkel_queue

# ===== Email / SMTP Gmail =====
# SMTP_USER = email pengirim
# SMTP_PASS = App Password 16 digit dari Google (bukan password biasa)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_NAMA=Bengkel Jaya Motor
